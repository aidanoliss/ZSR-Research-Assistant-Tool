{
  "name": "zsr-research-navigator",
  "version": "1.0.0",
  "private": true,
  "description": "Prototype AI research navigator for Wake Forest ZSR Library workflows.",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "concurrently -n server,client -c blue,green \"npm:dev:server\" \"npm:dev:client\"",
    "dev:server": "node --watch server/index.js",
    "dev:client": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "start": "node server/index.js",
    "test": "node --test test/validate.test.js test/screen.test.js test/research-agent.test.js"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^8.2.2",
    "vite": "^5.4.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  }
}
